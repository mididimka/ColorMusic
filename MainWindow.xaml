<Window x:Class="ColorMusic.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        Title="ColorMusic"
        Height="720"
        Width="1280"
        Background="Black"
        Icon="pack://application:,,,/Assets/icon.ico"
        KeyDown="Window_KeyDown"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Canvas Name="SmokeCanvas"/>
        <Canvas Name="BackgroundCanvas"/>
        <Canvas Name="LightsCanvas"/>

        <Border Name="SettingsPanel"
                Background="#DD0A0F18"
                HorizontalAlignment="Right"
                Width="450"
                Padding="10"
                CornerRadius="14"
                Margin="10"
                BorderBrush="#334C6A"
                BorderThickness="1">

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <TextBlock Text="🎛 Настройки"
                               FontSize="18"
                               Foreground="White"
                               FontWeight="Bold"
                               Margin="0,0,0,8"/>

                    <DockPanel Margin="0,0,0,6"
                               ToolTip="Общий уровень яркости прожекторов после всех расчётов.">
                        <TextBlock Text="Ур."
                                   Foreground="#88FFFFFF"
                                   Width="70"
                                   ToolTip="Общий уровень"/>
                        <Slider Name="MasterGainSlider"
                                Minimum="0"
                                Maximum="3"
                                ValueChanged="MasterGainSlider_ValueChanged"/>
                    </DockPanel>

                    <DockPanel Margin="0,0,0,6"
                               ToolTip="Общая чувствительность анализа музыки.">
                        <TextBlock Text="Чув."
                                   Foreground="#88FFFFFF"
                                   Width="70"
                                   ToolTip="Чувствительность"/>
                        <Slider Name="GlobalSensitivitySlider"
                                Minimum="0.1"
                                Maximum="20"
                                ValueChanged="GlobalSensitivitySlider_ValueChanged"/>
                    </DockPanel>

                    <DockPanel Margin="0,0,0,6"
                               ToolTip="Общая прозрачность прожекторов. В минимуме прожекторы полностью исчезают.">
                        <TextBlock Text="Прозр."
                                   Foreground="#88FFFFFF"
                                   Width="70"
                                   ToolTip="Прозрачность прожекторов"/>
                        <Slider Name="BaseOpacitySlider"
                                Minimum="0"
                                Maximum="1.0"
                                ValueChanged="BaseOpacitySlider_ValueChanged"/>
                    </DockPanel>

                    <DockPanel Margin="0,0,0,6"
                               ToolTip="Желаемая средняя яркость сцены для автоуровня.">
                        <TextBlock Text="Авто-ц."
                                   Foreground="#88FFFFFF"
                                   Width="70"
                                   ToolTip="Цель автоуровня"/>
                        <Slider Name="AutoLevelTargetSlider"
                                Minimum="0.05"
                                Maximum="1.0"
                                ValueChanged="AutoLevelTargetSlider_ValueChanged"/>
                    </DockPanel>

                    <WrapPanel Margin="0,0,0,8">
                        <CheckBox Name="SmokeCheckBox"
                                  Content="Дым"
                                  Foreground="White"
                                  Margin="0,0,10,0"
                                  ToolTip="Фоновый дым."
                                  Checked="SmokeCheckBox_Checked"
                                  Unchecked="SmokeCheckBox_Checked"/>

                        <CheckBox Name="AutoLevelCheckBox"
                                  Content="Авто"
                                  Foreground="White"
                                  Margin="0,0,10,0"
                                  ToolTip="Автоматически подстраивает яркость сцены."
                                  Checked="AutoLevelCheckBox_Checked"
                                  Unchecked="AutoLevelCheckBox_Checked"/>

                        <CheckBox Name="PulseCheckBox"
                                  Content="Пульс"
                                  Foreground="White"
                                  Margin="0,0,10,0"
                                  ToolTip="Пульсация прожекторов."
                                  Checked="PulseCheckBox_Checked"
                                  Unchecked="PulseCheckBox_Checked"/>

                        <CheckBox Name="StrobeCheckBox"
                                  Content="Строб"
                                  Foreground="White"
                                  Margin="0,0,10,0"
                                  ToolTip="Короткие яркие вспышки."
                                  Checked="StrobeCheckBox_Checked"
                                  Unchecked="StrobeCheckBox_Checked"/>

                        <CheckBox Name="BeatFlashCheckBox"
                                  Content="Бит"
                                  Foreground="White"
                                  Margin="0,0,10,0"
                                  ToolTip="Вспышки по басовым ударам."
                                  Checked="BeatFlashCheckBox_Checked"
                                  Unchecked="BeatFlashCheckBox_Checked"/>

                        <CheckBox Name="NeonCheckBox"
                                  Content="Неон"
                                  Foreground="White"
                                  ToolTip="Усиливает свечение прожекторов."
                                  Checked="NeonCheckBox_Checked"
                                  Unchecked="NeonCheckBox_Checked"/>
                    </WrapPanel>

                    <DockPanel Margin="0,0,0,6"
                               ToolTip="Сила эффекта пульсации.">
                        <TextBlock Text="Пульс"
                                   Foreground="#88FFFFFF"
                                   Width="70"
                                   ToolTip="Сила пульсации"/>
                        <Slider Name="PulseStrengthSlider"
                                Minimum="0"
                                Maximum="3"
                                ValueChanged="PulseStrengthSlider_ValueChanged"/>
                    </DockPanel>

                    <DockPanel Margin="0,0,0,6"
                               ToolTip="Сила эффекта стробоскопа.">
                        <TextBlock Text="Строб"
                                   Foreground="#88FFFFFF"
                                   Width="70"
                                   ToolTip="Сила стробоскопа"/>
                        <Slider Name="StrobeStrengthSlider"
                                Minimum="0"
                                Maximum="3"
                                ValueChanged="StrobeStrengthSlider_ValueChanged"/>
                    </DockPanel>

                    <DockPanel Margin="0,0,0,6"
                               ToolTip="Сила вспышек по битам.">
                        <TextBlock Text="Бит"
                                   Foreground="#88FFFFFF"
                                   Width="70"
                                   ToolTip="Сила вспышек по битам"/>
                        <Slider Name="BeatStrengthSlider"
                                Minimum="0"
                                Maximum="3"
                                ValueChanged="BeatStrengthSlider_ValueChanged"/>
                    </DockPanel>

                    <DockPanel Margin="0,0,0,6"
                               ToolTip="Сила неонового свечения.">
                        <TextBlock Text="Неон"
                                   Foreground="#88FFFFFF"
                                   Width="70"
                                   ToolTip="Сила неонового свечения"/>
                        <Slider Name="NeonStrengthSlider"
                                Minimum="0"
                                Maximum="3"
                                ValueChanged="NeonStrengthSlider_ValueChanged"/>
                    </DockPanel>

                    <ComboBox Name="ModeComboBox"
                              Margin="0,0,0,10"
                              ToolTip="Режим реакции. Мягкий — плавнее, Клубный — агрессивнее."
                              SelectionChanged="ModeComboBox_SelectionChanged"/>

                    <TabControl Name="ChannelTabs"
                                Background="#111827"
                                BorderBrush="#334C6A"
                                BorderThickness="1"
                                Padding="4">
                        <TabControl.Resources>
                            <Style TargetType="TabItem">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="Padding" Value="10,5"/>
                                <Setter Property="Background" Value="#162033"/>
                                <Setter Property="BorderBrush" Value="#334C6A"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Style>
                        </TabControl.Resources>
                    </TabControl>

                    <TextBlock Foreground="#55FFFFFF"
                               Text="F1 — панель | F2 — спектр | F11 — полный экран"
                               Margin="0,10,0,0"
                               FontSize="11"/>

                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>